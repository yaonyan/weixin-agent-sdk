{
  "_comment": "weixin-acp profile config — place at ~/.config/weixin-acp/acp-profiles.json — override with WEIXIN_ACP_STATE_DIR or XDG_CONFIG_HOME",
  "profiles": {
    "claude-code": {
      "command": "claude-agent-acp"
    },
    "codex": {
      "command": "codex-acp"
    },
    "gemini-internal": {
      "command": "gemini-internal",
      "args": ["--experimental-acp"]
    },
    "copilot": {
      "command": "copilot",
      "args": ["--acp"]
    }
  },
  "activeProfile": "copilot",
  "defaultProfile": "copilot"
}
